import numpy as np
import timeit

np.random.seed(42)
n_days = 100
daily_ret = np.random.randn(n_days) * 0.02
prices = 100 * np.exp(np.cumsum(daily_ret))

def ma_convolve(data, window):
    return np.convolve(data, np.ones(window) / window, mode='valid')

def ma_cumsum(data, window):
    cumsum = np.cumsum(data)
    cumsum[window:] = cumsum[window:] - cumsum[:-window]
    return cumsum[window - 1:] / window

ma5 = ma_cumsum(prices, 5)
ma20 = ma_cumsum(prices, 20)

print(f"股价长度: {len(prices)}")
print(f"5日均线长度: {len(ma5)}，前3个值: {ma5[:3].round(2)}")
print(f"20日均线长度: {len(ma20)}，前3个值: {ma20[:3].round(2)}")
print(f"convolve与cumsum结果一致: {np.allclose(ma_convolve(prices, 5), ma5)}")

n_runs = 1000
t_conv = timeit.timeit(lambda: ma_convolve(prices, 20), number=n_runs)
t_cumsum = timeit.timeit(lambda: ma_cumsum(prices, 20), number=n_runs)

print(f"\n20日均线性能对比:")
print(f"convolve:  千次耗时 {t_conv:.4f} 秒")
print(f"cumsum:    千次耗时 {t_cumsum:.4f} 秒")
